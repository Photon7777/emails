# Copy this file to .env and fill in your real values.
# Never commit .env, credentials.json, or token.json.

# Apollo
APOLLO_API_KEY=replace_with_your_apollo_api_key
APOLLO_AUTH_MODE=x-api-key
APOLLO_BASE_URL=https://api.apollo.io/api/v1

# Lead search filters
# Most lists are comma-separated.
APOLLO_FILTER_JOB_TITLES=University Recruiter,Campus Recruiter,Early Talent Recruiter,Technical Recruiter,Recruiter,Talent Acquisition Specialist,Founder,Co-Founder,Hiring Manager,Data Analytics Manager,Data Science Manager,Machine Learning Manager,AI Engineering Manager,Head of Data,Director of Analytics
APOLLO_TARGET_JOB_TITLES=Data Analyst Intern,Data Scientist Intern,Data Engineer Intern,Business Analyst Intern,Analytics Intern,BI Intern,AI/ML Intern,Cloud/Data Intern
APOLLO_TARGET_JOB_LOCATIONS=Washington DC,District of Columbia,DC,Maryland,MD,Virginia,VA,Remote
APOLLO_FILTER_PERSON_LOCATIONS=Washington DC,Maryland,Virginia
APOLLO_FILTER_LOCATIONS=Washington DC,District of Columbia,Maryland,Virginia,Arlington,Alexandria,Fairfax,Tysons,Reston,Rockville,Bethesda,College Park,Silver Spring,Baltimore,Gaithersburg,Richmond
APOLLO_FILTER_INDUSTRIES=computer software,financial services,healthcare,analytics
APOLLO_FILTER_KEYWORDS=summer 2026 internship,data analyst,business analyst,analytics,AI,ML,cloud,data engineering

# Company size ranges use semicolons because each Apollo range contains a comma.
# Examples: 1,10;11,50;51,200;201,500;501,1000;1001,5000
APOLLO_FILTER_COMPANY_SIZE_RANGES=1,10;11,50;51,200;201,500;501,1000;1001,5000;5001,10000;10001,20000

# Use a company prefilter when you want stricter industry/company matching.
# Note: Apollo's Organization Search endpoint may consume credits.
APOLLO_USE_ORGANIZATION_PREFILTER=false
APOLLO_MAX_ORGANIZATIONS=50

# Search volume
APOLLO_FETCH_PER_PAGE=50
APOLLO_FETCH_MAX_PAGES=20
APOLLO_INCLUDE_SIMILAR_TITLES=true
APOLLO_CONTACT_EMAIL_STATUSES=verified,likely to engage
APOLLO_ENRICH_MISSING_EMAILS=true
APOLLO_REVEAL_PERSONAL_EMAILS=false
APOLLO_DAILY_CREDIT_LIMIT=25
DAILY_ENRICH_LIMIT=25
# Optional: Apollo plan usage shown on the dashboard overview.
# Apollo's public usage endpoint exposes API rate limits, not plan credit balance,
# so set this manually in .env or Streamlit secrets from the Apollo credits page.
APOLLO_TOTAL_CREDITS=2630
APOLLO_ACCOUNT_CREDITS_USED=535
APOLLO_CREDIT_RENEWAL=Jun 4, 2026, 2:41 AM

# Qualification gates before Apollo enrichment.
LEAD_SCORE_THRESHOLD=70
MIN_SCORE_TO_ENRICH=55
MIN_SCORE_TO_SEND=70
MAX_CONTACTS_PER_COMPANY_PER_WEEK=2
ALLOW_UNVERIFIED_EMAIL_PATTERNS=false

# Gmail OAuth files
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Sender identity. Use your real details before sending live email.
SENDER_NAME=Sai Praneeth
SENDER_EMAIL=your.email@gmail.com
SENDER_ROLE=Data Analytics, Data Science, and Data Engineering Candidate
SENDER_LOCATION=
SENDER_LINKEDIN=https://www.linkedin.com/in/your-profile
SENDER_PORTFOLIO=https://your-portfolio.example.com
SENDER_PHYSICAL_ADDRESS=
SENDER_BACKGROUND=I work across data analytics, data science, and data engineering, including Python, SQL, dashboards, machine learning, and data pipelines.
ATTACH_RESUME=true
RESUME_FILE=/Users/yourname/Documents/Resume/Resume.pdf

# Email content
EMAIL_SUBJECT=Data / AI internship interest at {company_name}
EMAIL_TEMPLATE_PATH=templates/internship_outreach.txt
UNSUBSCRIBE_TEXT=

# Sending controls
DRY_RUN=true
# Leave blank unless you are intentionally running `python run_sender.py --live`.
# LIVE_SEND_CONFIRM=I_UNDERSTAND_SEND_LIVE_EMAILS
DAILY_SEND_LIMIT=30
DAILY_SEND_TARGET_MIN=25
PENDING_INVENTORY_TARGET=40
DELAY_BETWEEN_EMAILS_SECONDS=45
MAX_RETRIES=3

# Database
# Leave DATABASE_URL blank to use local SQLite. Set it to a Neon/Supabase
# Postgres connection string to share data between the Mac automation and
# a deployed Streamlit dashboard.
DATABASE_URL=
DATABASE_PATH=data/leads.sqlite

# Local files
LEADS_CSV_PATH=data/leads_export.csv
EMAIL_PREVIEW_PATH=data/email_previews.txt
SUPPRESSION_LIST_PATH=data/suppression_list.txt
DO_NOT_CONTACT_PATH=data/do_not_contact.txt
ALREADY_CONTACTED_PATH=data/already_contacted.txt
LOG_FILE=logs/cold_email_workflow.log
